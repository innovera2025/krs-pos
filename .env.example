# =============================================================================
# Database roles & connection strings (least-privilege, Phase 3)
# =============================================================================
# Two roles, two connection strings:
#   * The DB SUPERUSER (POSTGRES_USER) owns the cluster + runs migrations (DDL).
#   * The least-privilege app role (krs_app) runs the app (DML only: SELECT/
#     INSERT/UPDATE — no DELETE, no DDL). It is created once on a fresh data dir
#     by db/init/01-app-role.sh.

# --- DB superuser + database (db image init + the `migrate` service) ----------
# Cluster owner. Used by the postgres image entrypoint AND by `prisma migrate
# deploy`, which needs DDL privileges the app role intentionally lacks.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="CHANGE_ME"
POSTGRES_DB="krs_pos"

# --- Least-privilege app role (created by db/init/01-app-role.sh) -------------
# DML-only role the running app connects as. APP_DB_USER defaults to krs_app.
APP_DB_USER="krs_app"
APP_DB_PASSWORD="CHANGE_ME"

# --- DATABASE_URL: the APP (least-privilege) connection ----------------------
# Used by the `app` service / the running app (Prisma). This is the krs_app role
# above — DML only. Host-run dev (app on host, db in docker compose): localhost.
DATABASE_URL="postgresql://krs_app:CHANGE_ME@localhost:5432/krs_pos?schema=public"
# When the app runs INSIDE docker compose, point at the `db` service host:
#   DATABASE_URL="postgresql://krs_app:CHANGE_ME@db:5432/krs_pos?schema=public"

# --- MIGRATE_DATABASE_URL: the MIGRATIONS (superuser) connection -------------
# Used ONLY by the one-shot `migrate` service (prisma migrate deploy). This is
# the POSTGRES_USER superuser above — DDL is required to create/alter tables.
MIGRATE_DATABASE_URL="postgresql://postgres:CHANGE_ME@db:5432/krs_pos?schema=public"
# Host-run migrations (CLI on host against the compose db): use localhost:
#   MIGRATE_DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/krs_pos?schema=public"

# =============================================================================
# Auth.js
# =============================================================================
# Auth.js v5 (next-auth) session-signing secret. REQUIRED — the JWT session
# cookie is signed/encrypted with this; src/lib/env.ts fail-fasts at runtime if it
# is missing or shorter than 16 chars. docker-compose passes it to the app service,
# so it MUST be set in the git-ignored .env. Generate a real random value (do NOT
# use this placeholder; must be >= 16 chars) with either:
#   openssl rand -hex 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Never commit a real secret here.
AUTH_SECRET="CHANGE_ME"
# Auth.js infers the base URL in dev; set AUTH_URL explicitly behind a proxy or
# at a non-default origin (e.g. AUTH_URL="http://localhost:3000"). In production
# without AUTH_URL the app logs a startup warning (see src/lib/env.ts).
# AUTH_URL="http://localhost:3000"
# When the app runs behind a reverse proxy WITHOUT an explicit AUTH_URL, set
# AUTH_TRUST_HOST=true so Auth.js trusts the forwarded host header to build correct
# callback/redirect URLs. Leave unset for a directly-exposed origin.
# AUTH_TRUST_HOST="true"

# =============================================================================
# Seller identity for the Thai full tax invoice (ใบกำกับภาษีแบบเต็มรูป, §86/4)
# =============================================================================
# OPTIONAL at boot — a deploy that never issues a tax invoice (and CI/e2e) boots
# fine without these. They are ENFORCED at ISSUE time: the request-tax endpoint
# returns 422 SELLER_NOT_CONFIGURED if SELLER_TAX_ID / SELLER_NAME / SELLER_ADDRESS
# are unset, BEFORE minting a tax-invoice number. Shape is validated when present
# (see src/lib/env.ts). NEVER commit a real/fabricated TIN — use the placeholders.
#
# SELLER_TAX_ID — the seller's 13-digit Revenue-Department TIN (exactly 13 digits).
SELLER_TAX_ID="CHANGE_ME_13_DIGIT_TIN"
# SELLER_NAME — the seller's registered legal name as it appears on the tax invoice.
SELLER_NAME="CHANGE_ME_SELLER_NAME"
# SELLER_ADDRESS — the seller's full registered address (one line is fine).
SELLER_ADDRESS="CHANGE_ME_SELLER_ADDRESS"
# SELLER_BRANCH_CODE — the seller's 5-digit RD branch code. "00000" = สำนักงานใหญ่
# (head office). Defaults to HQ when unset.
SELLER_BRANCH_CODE="00000"
# SELLER_BRANCH_LABEL — human branch label (e.g. "สำนักงานใหญ่"). Defaults when unset.
SELLER_BRANCH_LABEL="สำนักงานใหญ่"
