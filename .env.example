# PostgreSQL connection string used by the app (Prisma).
# Host-run dev (app on host, db in docker compose): use localhost.
DATABASE_URL="postgresql://krs_app:CHANGE_ME@localhost:5432/krs_pos?schema=public"
# When the app runs INSIDE docker compose, point at the `db` service host:
#   DATABASE_URL="postgresql://krs_app:CHANGE_ME@db:5432/krs_pos?schema=public"

# Postgres credentials consumed by docker-compose.yml (the `db` service).
# Use a non-superuser-style app name (not the well-known `postgres` default).
# A true least-privilege app role (separate from the cluster owner) is a Phase 3 item.
POSTGRES_USER="krs_app"
POSTGRES_PASSWORD="CHANGE_ME"
POSTGRES_DB="krs_pos"
