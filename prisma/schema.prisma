// Prisma schema for KRS POS
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Customer / member (Phase 6a). Minimal by design: name + optional tax fields
// (taxId/address) needed to legally print a tax invoice header. The customer
// picker SELECTS seeded customers (no add-customer CRUD in 6a). A bill links to
// at most one customer (Order.customerId, nullable = walk-in). `address` carries
// the tax-invoice "ที่อยู่ออกใบกำกับ" address from the Simple POS IA.
model Customer {
  id        String   @id @default(cuid())
  name      String
  taxId     String?  @unique
  phone     String?
  address   String?
  // Buyer's RD branch designation for a full §86/4 tax invoice (Phase 4). The
  // 5-digit Revenue-Department branch code — "00000" = สำนักงานใหญ่ (head
  // office), "00001"+ = สาขาที่ N. Distinct from `branchId` below (which is the
  // SELLER's internal branch). Required on a full tax invoice so the buyer can
  // claim input VAT; defaults to HQ for the common single-branch buyer.
  buyerBranchCode String @default("00000")
  // Multi-branch-ready data model (domain-multi-branch-ready) — single-branch
  // deployments use the BR-01 default.
  branchId  String   @default("BR-01")
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// KRS accounting sync job (Phase 6a). A SIMULATED state machine — there is NO
// real KRS transport in P6; actions mutate `status` with canned responses, and
// `provider` is an open string field so other accounting providers can plug in
// later (real transport = production-readiness). 6a only creates the PENDING
// TAX_INVOICE job; the full 8-job seed + /data UI is Phase 6b.
model SyncJob {
  id        String        @id @default(cuid())
  type      SyncJobType
  direction SyncDirection @default(INSERT)
  ref       String
  amount    Decimal       @db.Decimal(12, 2) @default(0)
  status    SyncJobStatus @default(PENDING)
  provider  String        @default("KRS")
  error     String?
  response  String?
  branchId  String        @default("BR-01")
  // krs-sync P2 outbox extension — additive; all nullable/defaulted for back-compat.
  // These fields turn SyncJob into a durable outbox the dispatcher drains:
  //  - payload        : JSON snapshot of the POS sale captured at enqueue time. The
  //                     dispatcher reads THIS, never the live DB, so a later order/
  //                     product edit can't change what is written to KRS (no stale read).
  //  - idempotencyKey : "<orderNumber>_<jobType>" (e.g. "POS-20260625-0012_SALE").
  //                     @unique gives dedup protection; Postgres allows multiple NULLs
  //                     under a unique index so legacy seed rows are unaffected.
  //  - attempts       : count of dispatch attempts (terminal FAILED at maxAttempts).
  //  - lastError      : last attempt's sanitized error (distinct from `error`, the
  //                     terminal reason); never the raw mssql driver error.
  //  - nextAttemptAt  : retry gate — null = immediately eligible; future = backing off.
  //  - lockedAt       : dispatch lock — set on atomic claim, cleared on complete/fail;
  //                     a stale lock (older than the reclaim window) is re-claimable.
  payload        Json?
  idempotencyKey String?   @unique
  attempts       Int       @default(0)
  lastError      String?
  nextAttemptAt  DateTime?
  lockedAt       DateTime?
  krsClaimedTxnNo  String?   // SaleInvoiceTrNo burned in a SEPARATE committed phase-0 tx.
                            // Non-null = a prior attempt burned this number. Reclaim uses
                            // checkKrsSaleExists to decide: FOUND → markSynced; NOT FOUND
                            // → reuse via preClaimedSaleTxnNo (no new burn). Never cleared
                            // after a phase-1 failure — must be reused, never replaced.
  snapshotAdvancedAt DateTime? // krs-sync: set EXACTLY ONCE when the write-back's stock-cut
                            // is reflected into the global KrsStockSnapshot (warehouseCode="").
                            // The dispatcher decrements the snapshot by the sale's qty on the
                            // first attempt that reaches SYNCED (fresh write OR burned-anchor
                            // reclaim), guarded by `snapshotAdvancedAt IS NULL`, so the next
                            // auto-sync does NOT re-apply the sale's KRS on-hand drop as a
                            // fresh negative delta (which would double-count an already-
                            // decremented Product.stock). Null = not yet advanced.
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Dispatcher claim query filters PENDING/RETRYING jobs ordered by createdAt with a
  // lock + retry-gate predicate. Index the status to serve the claim scan efficiently.
  @@index([status, nextAttemptAt])
}

// Sync job kinds mirroring the Simple POS jobTypeLabel set (sale/refund/stock/
// pull/tax_invoice/stock_adj/receive).
enum SyncJobType {
  SALE
  REFUND
  STOCK
  PULL
  TAX_INVOICE
  STOCK_ADJ
  RECEIVE
}

// Outbound (POS → KRS) vs inbound (KRS → POS) data flow.
enum SyncDirection {
  INSERT
  PULL
}

// Sync job lifecycle states (Simple POS: pending/synced/failed/retrying/skipped).
enum SyncJobStatus {
  PENDING
  SYNCED
  FAILED
  RETRYING
  SKIPPED
  NEEDS_RECONCILE   // burned anchor held but existence check persistently fails;
                    // operator must reconcile before re-entry (NOT auto-claimable);
                    // UI-alias NOT updated in this pass (see Residual §6)
}

// Store-level settings singleton (Receipt print-size feature). Exactly ONE row
// (`id @default("singleton")`) holds the admin-configurable thermal-receipt page
// size: `receiptWidthMm` (40–120, preset 58/80 + free input), and the height
// either AUTO (`receiptHeightAuto = true`, the today/default behavior matching
// `@page { size: 80mm auto }`) or a FIXED `receiptHeightMm` (50–400). When
// `receiptHeightAuto` is true `receiptHeightMm` is forced NULL by the API.
//
// Seller identity (seller-company-settings) is now DB-PRIMARY here: the admin
// edits these from /settings and getSellerConfig() (sellerConfig.ts) reads them
// DB-first, falling back PER FIELD to the legacy `SELLER_*` ENV vars when a DB
// value is null/empty (zero-downtime upgrade for existing ENV-based deploys). All
// seller columns are nullable — null = "not set here, use ENV fallback". The
// §86/4 mandatory particulars (sellerName / sellerTaxId / sellerAddress) gate
// tax-invoice minting; sellerPhone / sellerPosId are receipt-only (never block
// minting); sellerBranchCode / sellerBranchLabel default to HQ "00000" /
// "สำนักงานใหญ่" when unset everywhere.
model ShopSettings {
  id                String   @id @default("singleton")
  receiptWidthMm    Int      @default(80)
  receiptHeightAuto Boolean  @default(true)
  receiptHeightMm   Int?
  // Seller identity (DB-primary, ENV fallback). §86/4 mandatory particulars:
  sellerName        String?  // registered legal name (≤200 chars)
  sellerTaxId       String?  // 13-digit Revenue-Department TIN
  sellerAddress     String?  // registered address (≤300 chars)
  // Receipt-only (optional, NOT §86/4 mandatory — never block minting):
  sellerPhone       String?  // contact phone for the thermal receipt (≤50 chars)
  sellerPosId       String?  // POS terminal ID for the thermal receipt (≤50 chars)
  // Branch designation (defaults to HQ in getSellerConfig when unset):
  sellerBranchCode  String?  // 5-digit RD branch code ("00000" = head office)
  sellerBranchLabel String?  // human branch label (≤100 chars)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role     @default(CASHIER)
  password  String
  // Activate/deactivate without a destructive delete (Phase 4 Users & Roles:
  // state-user-active-inactive). A deactivated user is hidden/blocked, never removed.
  isActive  Boolean  @default(true)
  // Account lockout (auth Phase 3). `failedLoginAttempts` counts consecutive bad
  // sign-ins; at the threshold (10) `lockedUntil` is set to now+15min. A success
  // resets both to 0/null. Auto-expires at `lockedUntil`; an admin can also clear
  // them via the {action:"unlock"} PATCH variant. Persistent (survives restart),
  // complementing the in-memory per-IP rate-limiter in src/lib/rateLimit.ts.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  // Force-logout-all (auth Phase 3). Stamped onto the JWT at sign-in; the jwt
  // callback re-reads it every request and invalidates a token whose stamped
  // version is stale. Admin "force logout" increments this → every existing JWT
  // for the user is rejected on its next request. (JWT-compatible session
  // revocation; per-device listing needs a Session table and is deferred.)
  tokenVersion        Int       @default(0)
  // Multi-branch-ready data model (domain-multi-branch-ready) — a user belongs to
  // a branch. Single-branch deployments use the BR-01 default. Surfaced in the
  // Users & Roles table and selected by the users API.
  branchId  String   @default("BR-01")
  // Branch/Warehouse program (Phase 2): the user's assigned KRS WarehouseCode
  // (e.g. "WH01"), or null = unassigned. ⚠️ ID namespaces — this stores the KRS
  // WarehouseCode ONLY; the branch is DERIVED from the Warehouse master (WH→branch
  // is 1:1 in KRS), so branchCode is NEVER stored or conflated here. Plain nullable
  // string (no FK) — the users API validates it against the Warehouse table on
  // every write (never trust the client). Additive + inert downstream: nothing in
  // checkout/auth/session/stock reads it yet (that is Phase 3+).
  warehouseCode String?
  orders    Order[]
  // Shifts this user opened/owns as cashier (Phase 5: flow-shift-lifecycle).
  shifts    Shift[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
}

// Audit trail (auth Phase 3). Append-only security/event log: who did what, to
// what, from where. Writes are BEST-EFFORT (src/lib/auditLog.ts) — a failed
// audit write never fails the primary action and is NEVER done inside a
// $transaction. `detail` holds a small JSON string for action-specific context
// (e.g. {orderNumber,total} for a refund). No FK on actorId/targetId so a row
// survives even if the referenced record is later changed.
model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  actorEmail String?
  action     AuditAction
  targetType String?
  targetId   String?
  ip         String?
  detail     String?
  createdAt  DateTime    @default(now())

  @@index([action, createdAt])
  @@index([actorId, createdAt])
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGIN_RATE_LIMITED
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  LOGOUT
  PASSWORD_CHANGED
  USER_CREATED
  USER_DEACTIVATED
  USER_ACTIVATED
  // Sale created at checkout (Financial/Inventory correctness, Sub-phase B). The
  // POST /api/orders success path writes this best-effort, AFTER commit — the
  // money-trail counterpart to ORDER_REFUNDED / ORDER_VOIDED.
  ORDER_CREATED
  ORDER_REFUNDED
  ORDER_VOIDED
  SESSION_REVOKED
  // KRS connection settings changed (krs-sync P1). Written best-effort, AFTER the
  // KrsConnectionSettings upsert commits, when `host` (or `port`) changes — the
  // compensating audit control for the deliberate no-private-IP-denylist SSRF
  // stance (P0 spec §1.2.1). `detail` holds {newHost,newPort} JSON.
  KRS_SETTINGS_CHANGED
  // Promotion lifecycle (promotions program, Phase 2). Written best-effort AFTER a
  // Promotion create/update/toggle commits — the audit-trail counterpart for the
  // ADMIN-only (strict-ADMIN; MANAGER excluded) promotion management surface.
  // ACTIVATED / DEACTIVATED capture the `isActive` soft-delete toggle (no hard
  // DELETE); `detail` holds the promotion id/name/type JSON.
  PROMOTION_CREATED
  PROMOTION_UPDATED
  PROMOTION_ACTIVATED
  PROMOTION_DEACTIVATED
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  sku         String      @unique
  price       Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  barcode     String?     @unique
  imageUrl    String?
  isActive    Boolean     @default(true)
  // Ghost-product reconciliation (17-07-26 incident). true = this row is owned/
  // synced by the KRS product import (importKrsProducts) and is therefore ELIGIBLE
  // for automatic deactivation when its sku disappears from the KRS product master
  // (a DELETED KRS ItemCode — the "ghost" the 17-07-26 incident left behind).
  // false = manually created in the POS UI (POST /api/products) and NEVER
  // auto-deactivated. NO BACKFILL MIGRATION: the importer STAMPS this true on every
  // create AND update, so within one import cycle (~1 min in prod) every KRS-fed row
  // converges to true with ZERO risk to manual/seed rows. The reconciler ONLY ever
  // acts on rows where krsManaged = true, which by construction have been seen in a
  // KRS feed at least once post-deploy.
  krsManaged  Boolean     @default(false)
  // Multi-branch-ready data model (domain-multi-branch-ready) — deferred from
  // Phase 1, added here. Single-branch deployments use the BR-01 default.
  branchId    String      @default("BR-01")
  categoryId  String?
  category    Category?   @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  movements   StockMovement[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique
  // Checkout idempotency (Financial/Inventory correctness, Sub-phase C). A
  // client-generated UUID per checkout ATTEMPT (reused across retries of the
  // same submission, regenerated for a new sale). The `@unique` index makes a
  // double-submit / network retry collapse to a single Order: the POST pre-checks
  // by this key and returns the existing order (200 replay) instead of creating a
  // duplicate sale + double stock decrement. Nullable for back-compat (older rows
  // and any client that omits it); `@unique` allows multiple NULLs in Postgres.
  idempotencyKey String?   @unique
  status       OrderStatus @default(COMPLETED)
  subtotal     Decimal     @db.Decimal(10, 2)
  tax          Decimal     @db.Decimal(10, 2) @default(0)
  discount     Decimal     @db.Decimal(10, 2) @default(0)
  total        Decimal     @db.Decimal(10, 2)
  // Bill-level promotion (promotions program, Phase 2). `discount` above KEEPS its
  // meaning = the TOTAL bill-level discount (manual + promo), so the invariant
  // `subtotal − discount === total` is unchanged everywhere (checkout, writeback
  // assert, Z-report, sales history). `promoBillDiscount` is the promo SLICE of that
  // discount (manual slice = discount − promoBillDiscount); `billPromotionId` /
  // `billPromotionName` snapshot the applied BILL_THRESHOLD promo — NO FK, the same
  // historical-immutability stance as OrderItem.promotionId (a promo edit must never
  // touch a past sale). 0 / null = no bill-level promotion.
  promoBillDiscount Decimal @db.Decimal(10, 2) @default(0)
  billPromotionId   String?
  billPromotionName String?
  paymentType  PaymentType @default(CASH)
  amountPaid   Decimal     @db.Decimal(10, 2) @default(0)
  change       Decimal     @db.Decimal(10, 2) @default(0)
  // Multi-branch-ready data model (domain-multi-branch-ready) — deferred from
  // Phase 1, added here. Single-branch deployments use the BR-01 default.
  branchId     String      @default("BR-01")
  cashierId    String?
  cashier      User?       @relation(fields: [cashierId], references: [id])
  // Customer linkage (Phase 6a). Nullable = walk-in (ลูกค้าทั่วไป); a checkout
  // never blocks when no customer is selected. Required (with a taxId) only when
  // a tax invoice is requested (domain-tax-invoice-requires-tax-customer).
  customerId   String?
  customer     Customer?   @relation(fields: [customerId], references: [id])
  // Shift linkage (Phase 5 Decision A2: add shiftId FK on Order). Nullable so a
  // checkout never blocks when no shift is open — the POST sets it to the current
  // OPEN shift if one exists, else leaves it null. The Z-report aggregates the
  // shift's orders by this FK.
  shiftId      String?
  shift        Shift?      @relation(fields: [shiftId], references: [id])
  // Sync lifecycle stub (Phase 5). Real KRS sync state machine is Phase 6; this
  // field exists now so the seed can express synced/daily/failed/skipped states
  // and the void-lock rule (domain-synced-bills-locked) can be enforced.
  syncStatus   SyncStatus  @default(PENDING)
  // Accounting document number (TAX-…, CN-…). The sequential §86/4 tax-invoice
  // number is minted LOCALLY at request-tax time (Phase 4, D1) and written here.
  // @unique is a DB backstop (FIX 5) against any duplicate doc number — pairs with
  // the in-tx conditional mint guard (FIX 2). Nullable: Postgres allows many NULLs
  // under a unique index, so unrequested bills (and the single seeded value) are
  // fine.
  accountingDocNo String?     @unique
  // Tax-invoice ISSUE date (§86/4(7), FIX 1). Stamped at request-tax time from the
  // SAME Postgres-now / Asia/Bangkok basis as the number mint — this is the date
  // the invoice was ISSUED, which for a post-sale request differs from
  // `createdAt` (the SALE date). The A4 document renders this; legacy rows
  // (null) fall back to createdAt.
  taxIssuedAt  DateTime?
  // Whether a tax invoice was requested for this bill (filter chip ขอใบกำกับ).
  taxRequested Boolean     @default(false)
  items        OrderItem[]
  // Split-payment breakdown (Phase 3). `paymentType` above stays the primary/
  // dominant method for reporting/back-compat; `payments` carries every tendered
  // line (method + amount + optional reference) — feeds the P5 by-method Z-report.
  payments     PaymentLine[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Recent-orders sort: GET /api/orders defaults to orderBy { createdAt: desc }
  // and Sales History lists newest-first — index the sort key.
  @@index([createdAt])
  // `?status=` filter + createdAt sort (e.g. COMPLETED-only history/aggregates):
  // composite so the filter+sort is served by one index.
  @@index([status, createdAt])
  // Z-report aggregates a shift's orders by this FK. Postgres does NOT auto-index
  // foreign keys, so add it explicitly for the per-shift lookup.
  @@index([shiftId])
}

// Collision-safe daily POS number sequence (Financial/Inventory correctness,
// Sub-phase C). One row per Asia/Bangkok calendar day; `seq` is bumped atomically
// inside the checkout transaction via a raw `INSERT ... ON CONFLICT DO UPDATE
// SET seq = seq + 1 RETURNING seq` upsert (race-free, unlike a find-then-write).
// This replaces the old count-based `nextPosNo`, which could mint duplicate
// orderNumbers under concurrent checkouts (READ COMMITTED). `orderNumber` is
// derived as `POS-${day}-${seq padded to 4}`.
model DailyOrderCounter {
  // "YYYYMMDD" in Asia/Bangkok (matches bangkokDayStamp / bangkokYyyymmdd).
  day String @id
  seq Int    @default(0)
}

// Sequential tax-invoice number counter (Phase 4 — Thai full §86/4 invoice). One
// row per Asia/Bangkok calendar YEAR; `seq` is bumped atomically at request-tax
// time via a raw `INSERT ... ON CONFLICT (year) DO UPDATE SET seq = seq + 1
// RETURNING seq` upsert — race-free, mirroring DailyOrderCounter. Yearly reset
// (D5): the issued number is `TAX-${year}-${seq padded to 6}` (matches the seed
// `TAX-2026-000418`). Minted INSIDE the request-tax transaction so a rolled-back
// request does not consume a tax-invoice number. The §86/4(4) serial requirement
// (strict ascending, no reuse) is satisfied by the atomic per-year sequence.
model TaxInvoiceCounter {
  // "YYYY" in Asia/Bangkok (derived from the Postgres transaction clock).
  year String @id
  seq  Int    @default(0)
}

enum OrderStatus {
  PENDING
  COMPLETED
  REFUNDED
  // Void ≠ Cancelled in the POS domain (Simple POS source-of-truth). A voided
  // bill is zeroed and skipped from sync; CANCELLED is kept for back-compat.
  VOIDED
  CANCELLED
}

// Sync lifecycle states (Phase 5 stub; real KRS sync = Phase 6). Mirrors the
// Simple POS sync values: pending / daily / synced / failed / skipped.
enum SyncStatus {
  PENDING
  DAILY
  SYNCED
  FAILED
  SKIPPED
}

enum PaymentType {
  CASH
  CARD
  QR
  TRANSFER
  // Retired as POS tender buttons (vendor 17-07-26) but KEPT here so historical rows
  // that already stored these values continue to read/serialize correctly.
  EWALLET
  OTHER
  // Added 17-07-26 so POS tender methods map 1:1 onto the KRS Receipt_Type codes
  // (CHEQUE→3 เช็ค, THAICHUAYTHAI→5 ไทยช่วยไทย). Schema-additive — no value removed.
  CHEQUE
  THAICHUAYTHAI
}

model PaymentLine {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method    PaymentType
  amount    Decimal     @db.Decimal(10, 2)
  reference String?
  createdAt DateTime    @default(now())
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  lineTotal  Decimal  @db.Decimal(10, 2)
  // Line-level promotion snapshot (promotions program, Phase 2). DELIBERATELY NO
  // relation/FK to Promotion — a later promo edit/deactivate must never touch a
  // historical sale (same snapshot stance as HeldBill.customerId). `promotionId` /
  // `promotionName` record which line promo (type 1-3) applied at sale time.
  // `promoDiscount` is the promo portion ALREADY folded into `lineTotal` (lineTotal
  // = unitPrice×quantity − manualLineDiscount − promoDiscount), so the manual portion
  // is recoverable as unitPrice×quantity − lineTotal − promoDiscount. Null / 0 = no
  // promotion on this line.
  promotionId   String?
  promotionName String?
  promoDiscount Decimal  @db.Decimal(10, 2) @default(0)
  createdAt  DateTime @default(now())

  // Z-report promo breakdown groups OrderItem rows by promotionId (COMPLETED-only);
  // Postgres does not auto-index this non-FK column, so add it for the per-promo scan.
  @@index([promotionId])
}

// Stock movement ledger (Phase 4: action-receive-stock / flow-product-stock).
// RECEIVE = goods-received note (GRN, +stock); SALE/ADJUST are reserved for
// future wiring (POS sale decrements / manual corrections). Each movement
// records the signed/positive qty plus an optional reference (e.g. PO number).
enum StockMovementType {
  RECEIVE
  SALE
  ADJUST
  KRS_SYNC   // auto-pull delta (ERP receipt/adjustment applied to POS stock)
}

model StockMovement {
  id        String            @id @default(cuid())
  productId String
  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      StockMovementType
  qty       Int
  reference String?
  branchId  String            @default("BR-01")
  createdAt DateTime          @default(now())
}

// Cash-drawer shift (Phase 5: flow-shift-lifecycle). A shift is opened with an
// opening cash float, accumulates orders (Order.shiftId), and is closed with the
// counted cash — driving the Z-report and cash-variance. Append-only: a closed
// shift is never deleted (domain-no-destructive-delete).
model Shift {
  id           String       @id @default(cuid())
  shiftNumber  String       @unique
  status       ShiftStatus  @default(OPEN)
  openedAt     DateTime     @default(now())
  closedAt     DateTime?
  openingFloat Decimal      @db.Decimal(10, 2) @default(0)
  countedCash  Decimal?     @db.Decimal(10, 2)
  cashierId    String?
  cashier      User?        @relation(fields: [cashierId], references: [id])
  branchId     String       @default("BR-01")
  orders       Order[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum ShiftStatus {
  OPEN
  CLOSED
}

// KRS connection profile (krs-sync P1). Singleton — exactly ONE row, mirroring
// ShopSettings (id @default("singleton")). Stores the MS SQL Server connection
// parameters configured from the Admin /data Connection tab. The password is
// AES-256-GCM encrypted at rest (see encryptedPassword); plaintext never persists.
// This model is connection CONFIG only — the live mssql ConnectionPool is opened
// in src/lib/krs/client.ts, NOT here, and NEVER via the Prisma singleton.
model KrsConnectionSettings {
  id                String   @id @default("singleton")
  host              String                                  // SQL Server hostname or IP
  port              Int      @default(1433)                 // SQL Server default port
  database          String                                  // target database name
  username          String                                  // SQL Server SQL-auth username
  encryptedPassword String?                                 // AES-256-GCM blob (see lib/krs/crypto.ts); null = not yet set
  ssl               Boolean  @default(true)                 // TLS / encrypt connection (mssql options.encrypt)
  trustServerCert   Boolean  @default(true)                 // trust a self-signed KRS cert when SSL is on (on-prem-friendly; mssql options.trustServerCertificate)
  engine            String   @default("SQLSERVER")          // fixed; read-only display in UI
  syncMode          String   @default("realtime")           // "realtime" | "daily" | "manual"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Configurable KRS field-mapping (krs-sync inbound import config). One row PER
// sync function, keyed by the function string (the row IS the singleton for that
// function). Only "PRODUCT_IMPORT" is wired today; the model is deliberately
// generic (function + sourceTable + fieldMap Json) so stock/customer/outbound
// functions can be added later WITHOUT a schema change.
//
//  - function    : the function key, e.g. "PRODUCT_IMPORT" (PK → one row/function)
//  - sourceTable : the KRS base-table name to read from (e.g. "InventoryItem").
//                  Validated against the LIVE introspection before persist + before
//                  any read — it feeds a QUOTENAME'd identifier, never raw SQL.
//  - fieldMap    : Json object { posTargetField -> krsColumnName } (e.g.
//                  { "sku": "ItemCode", "name": "ItemName", ... }). Keys are the
//                  known POS target fields; values are KRS column names, also
//                  validated to exist in `sourceTable` before persist + before read.
//
// When absent, the lib falls back to a typed in-code DEFAULT (the previously
// hardcoded mapping), so the feature is backward-compatible on a fresh deploy.
model KrsFieldMapping {
  function    String   @id                  // function key, e.g. "PRODUCT_IMPORT"
  sourceTable String                        // KRS base-table name (validated, QUOTENAME'd)
  fieldMap    Json                          // { posTargetField: krsColumnName }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// KRS on-hand snapshot per item PER WAREHOUSE (krs-sync inbound auto-pull). The
// primary key is the COMPOSITE (itemCode, warehouseCode) — one row per KRS ItemCode
// (= POS Product.sku) per warehouse. Stores the last-seen sp_Onhand Balqty so a
// delta engine can compute ERP-originated movements only (delta = currentKrsQty −
// lastSeenKrsQty). See src/lib/krs/autoSync.ts.
//
// warehouseCode SENTINEL — `warehouseCode = ""` (empty string) is the all-warehouse
// row used by the EXISTING global delta engine (sp_Onhand summed across every
// warehouse → the global Product.stock pass). Per-warehouse rows (Branch/Warehouse
// Phase 5) carry the real KRS WarehouseCode (e.g. "WH01") and feed future
// per-warehouse delta engines; today they are written for display only.
//
// The magic row (itemCode = "__LOCK__", warehouseCode = "") is the run-lock sentinel
// (lockedAt field); it is never a real product snapshot and is never included in
// delta computation.
//
// ADDITIVE-COMPATIBLE — the composite PK migration preserves every existing row by
// defaulting warehouseCode to "" (the global sentinel the prior single-key engine
// implicitly used).
model KrsStockSnapshot {
  itemCode      String                       // KRS ItemCode (trimmed) = POS Product.sku
  warehouseCode String    @default("")       // "" = all-warehouse sentinel (global engine); else the KRS WarehouseCode
  lastQty       Decimal   @db.Decimal(12, 4) // last seen sp_Onhand Balqty (raw fractional)
  lockedAt      DateTime?                    // run-lock sentinel (only itemCode="__LOCK__", warehouseCode="")
  updatedAt     DateTime  @updatedAt

  @@id([itemCode, warehouseCode])
}

// KRS realtime-inbound WATERMARK cursor (krs-realtime-inbound P1). Singleton — mirrors
// ShopSettings / KrsConnectionSettings (id @default("singleton")). Stores the last-seen
// KRS change WATERMARKS so the 2-second realtime poller (POST /api/krs/rt-poll) can
// cheaply detect "did anything move since last cycle?" with a single 4-aggregate probe.
//
// VARIANT NOTE: the plan (krs-realtime-inbound_PLAN_16-07-26.md) originally called this
// `KrsCtCursor` and stored a single SQL Server Change-Tracking version. The owner's
// 16-07-26 VARIANT SWITCH replaced Change Tracking with a vendor-free WATERMARK detector
// (references/krs-watermark-discovery_16-07-26.md), so this cursor stores the four
// observed watermarks instead of a CT version. Hence the rename to KrsWatermarkCursor.
//
// The watermarks come from `dbo.InventoryFlowHdr` (TransactionNo running number +
// EntryDate + ApprovedDate — the three signals that a stock movement/approval happened)
// and `dbo.InventoryItem` (EntryDate — a new product master row). A cursor value is
// advanced ONLY after a poll cycle fully applies (crash-safe replay: re-processing the
// same docs is idempotent because the reconcile re-reads scoped sp_Onhand truth, it does
// not blindly re-apply deltas).
model KrsWatermarkCursor {
  id              String    @id @default("singleton")
  lastTxn         Int       @default(0) // last-seen MAX(InventoryFlowHdr.TransactionNo)
  lastEntryAt     DateTime?             // last-seen MAX(InventoryFlowHdr.EntryDate)
  lastApprovedAt  DateTime?             // last-seen MAX(InventoryFlowHdr.ApprovedDate)
  lastItemEntryAt DateTime?             // last-seen MAX(InventoryItem.EntryDate)
  lastItemCount   Int       @default(-1) // -1 = not yet observed; COUNT(*) of dbo.InventoryItem at last cycle — deletion detector (a delete advances no MAX watermark but changes this count)
  lastCycleAt     DateTime?             // wall-clock time the last cycle that MOVED stock completed
  updatedAt       DateTime  @updatedAt
}

// Warehouse master (Branch/Warehouse program, Phase 1). Mirrors the KRS
// `dbo.Warehouse` table, pulled into POS the SAME way products are pulled
// (src/lib/krs/warehouses.ts → importWarehouses.ts → POST /api/krs/pull-warehouses).
// Seeded with the four known KRS warehouses (WH01–WH04) as a FALLBACK so the
// feature works before the first KRS pull.
//
//  - warehouseCode : the KRS WarehouseCode (e.g. "WH01") — the natural PK. NOTE the
//                    ID namespaces (never conflate): this is the KRS WarehouseCode,
//                    NOT the POS internal `branchId` ("BR-01") and NOT the KRS
//                    `branchCode` below.
//  - warehouseName : the KRS WarehouseName (Thai, e.g. "คลังปัตตานี").
//  - branchCode    : the KRS BranchCode this warehouse maps to (e.g. "00000"). The
//                    user's branch is DERIVED from this 1:1 WH→branch mapping
//                    (Phase 2+). 5-digit KRS branch code, distinct from POS branchId.
//
// ADDITIVE ONLY — no existing table altered; no existing flow touched.
model Warehouse {
  warehouseCode String   @id            // KRS WarehouseCode (e.g. "WH01")
  warehouseName String                  // KRS WarehouseName (Thai)
  branchCode    String                  // KRS BranchCode this warehouse maps to
  branchName    String?                 // KRS Branch.BranchName (via Branch join); nullable until a KRS pull/seed fills it
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Per-warehouse on-hand stock (Branch/Warehouse program, Phase 5 — DISPLAY-ONLY).
// One row per (sku, warehouseCode): the last-seen KRS sp_Onhand Balqty for that item
// in that warehouse, rounded + floored at 0. Written by the per-warehouse pass of
// the KRS auto-sync (src/lib/krs/autoSync.ts) and read by GET /api/products so the
// product grid's "หมด"/stock badge reflects the logged-in user's assigned warehouse
// (User.warehouseCode → session.user.warehouseCode).
//
// ⚠️ RAW KRS value — NOT POS-sale-adjusted. This mirrors KRS on-hand for display;
// it is NOT the authoritative sellable stock. Checkout still decrements/guards the
// global `Product.stock` (Phase 6 oversell guard is OUT OF SCOPE). When a user has
// no warehouse assigned, GET /api/products falls back to the global Product.stock.
//
// ADDITIVE ONLY — no existing table altered; no existing flow touched.
model WarehouseStock {
  sku           String   // KRS ItemCode (trimmed) = Product.sku
  warehouseCode String   // KRS WarehouseCode e.g. "WH01"
  qty           Int      @default(0) // last-seen sp_Onhand Balqty, rounded + floored >= 0; RAW KRS (display-only)
  updatedAt     DateTime @updatedAt

  @@id([sku, warehouseCode])
  // GET /api/products filters by warehouseCode ALONE on every product-grid load for a
  // warehouse-assigned user. The composite PK leads with `sku`, so it can't serve that
  // filter — index warehouseCode explicitly to avoid a per-request seq scan.
  @@index([warehouseCode])
}

// Parked / held bill ("พักบิล") — a server-side SNAPSHOT of an in-progress cart so a
// cashier can set a sale aside (e.g. customer fetches a forgotten item) and resume it
// later, surviving a page reload or a different terminal. ADDITIVE ONLY — no existing
// table altered; checkout/orders/money/stock/auth are untouched.
//
//  - label         : display label minted at park time ("HH:MM · {N} รายการ" — Thai
//                    24h time + total piece count).
//  - cartJson       : Json snapshot of the cart (HeldBillCartSnapshot): the line items
//                    (productId + qty + per-line discount, plus the product name/price/
//                    sku captured for list display) and the selected customer (or null
//                    walk-in). ⚠️ DISPLAY/RESTORE SNAPSHOT ONLY — checkout STILL
//                    recomputes ALL money/stock server-side from live DB prices on the
//                    resumed bill; the snapshot's prices are never trusted as authority.
//  - customerId     : plain TEXT (NOT a relation FK — no cascade): the customer the bill
//                    was parked with, or null (walk-in). Kept denormalized alongside the
//                    cartJson snapshot so a later customer edit/delete never mutates or
//                    breaks a parked bill.
//  - discountType /
//    discountValue  : the bill-level discount INPUT (฿/% mode + raw value) at park time,
//                    restored verbatim into the discount field on resume.
//  - taxRequested   : whether the tax-invoice toggle was on at park time.
//  - createdById    : the cashier who parked it (= session.user.id). Held bills are
//                    SCOPED PER-CASHIER — every read/delete filters by this so one
//                    cashier never sees or discards another's parked bill.
//  - branchId       : multi-branch-ready (domain-multi-branch-ready); single-branch
//                    deployments use the BR-01 default.
model HeldBill {
  id            String   @id @default(cuid())
  label         String
  cartJson      Json     // HeldBillCartSnapshot (see src/types/index.ts)
  customerId    String?  // plain TEXT, NOT a relation FK (no cascade)
  discountType  String   // "amount" | "percent"
  discountValue Float
  taxRequested  Boolean  @default(false)
  createdById   String   // cashier = session.user.id
  branchId      String   @default("BR-01")
  // SOFT-DELETE marker (least-privilege). The app DB role `krs_app` holds only
  // SELECT/INSERT/UPDATE — NOT DELETE (deliberate least-privilege; db/init/01-app-role.sh).
  // HeldBill is the first feature that would hard-DELETE, which fails with Postgres 42501.
  // Instead, "discard" and "consume-on-resume" set `resolvedAt` via UPDATE (allowed):
  //   null     = ACTIVE / open / still resumable (the default for every existing row)
  //   non-null = consumed (resumed) OR discarded — excluded from the GET list, never
  //              re-claimable by the atomic resume UPDATE. Resolved rows simply
  //              accumulate (small volume; a future cleanup job can purge — out of scope).
  resolvedAt    DateTime?
  createdAt     DateTime @default(now())

  // GET lists a cashier's parked bills ordered by createdAt — composite index serves
  // the per-cashier filter + sort in one scan.
  @@index([createdById, createdAt])
}

// Promotion (promotions program, Phase 2). ADMIN-authored (strict-ADMIN; MANAGER
// excluded) discount rule the POS applies automatically at checkout. Four kinds
// (see PromotionType): a line-level % / ฿ discount, a special fixed per-unit price,
// buy-X-get-Y on the SAME product (v1), and a whole-bill spend threshold.
//
// ⚠️ MONEY-UNIT CONVENTION — every configured money value here is an Int in SATANG
// (1 baht = 100 satang): `amountOffSatang`, `fixedPriceSatang`, `minSubtotalSatang`.
// These are ENGINE INPUTS (the promotion engine computes in integer satang, exactly
// like pricing.ts) and are JSON-safe plain ints (no Decimal trailing-zero pitfall).
// This is DELIBERATELY UNLIKE the Order money columns, which are Decimal(10,2) baht.
// `percentOff` is a Decimal(5,2) percent (e.g. 12.50), never a money amount.
//
// Per-type value fields are NULL when irrelevant to `type` and are enforced at the
// API boundary (Zod discriminated union), not by the DB — Postgres cannot express
// "these columns are required iff type = X".
model Promotion {
  id        String        @id @default(cuid())
  name      String        // Thai display name — shown on the POS screen + receipt
  code      String?       @unique // optional coupon/reference code (unique when set)
  type      PromotionType
  // Soft delete only (least-privilege: the app DB role `krs_app` has no DELETE —
  // see the HeldBill.resolvedAt precedent). Deactivating flips this to false; a
  // promotion row is never hard-removed.
  isActive  Boolean       @default(true)
  // Active WINDOW as UTC instants (null = open-ended on that side). The admin UI
  // works in Bangkok CALENDAR days and converts via src/lib/datetime.ts: `startsAt`
  // = 00:00 Bangkok of the start day; `endsAt` = the EXCLUSIVE 00:00 Bangkok of the
  // day AFTER the end day. A promotion is effective iff `startsAt <= now < endsAt`
  // (half-open), evaluated at the fetch boundary — the engine itself stays clock-free.
  startsAt  DateTime?
  endsAt    DateTime?
  // Multi-branch-ready data model (domain-multi-branch-ready) — single-branch
  // deployments use the BR-01 default.
  branchId  String        @default("BR-01")
  // Per-type value fields (NULL unless the `type` uses them; validated at the API
  // boundary). Money fields are Int SATANG (see the model note above):
  //  - PRODUCT_DISCOUNT : percentOff (Decimal %) OR amountOffSatang (฿ off per unit)
  //  - FIXED_PRICE      : fixedPriceSatang (special per-unit price)
  //  - BUY_X_GET_Y      : buyQty (X) + getQty (Y) + getDiscountPercent (% off the Y)
  //  - BILL_THRESHOLD   : minSubtotalSatang (spend gate) + percentOff OR amountOffSatang
  percentOff         Decimal? @db.Decimal(5, 2)
  amountOffSatang    Int?
  fixedPriceSatang   Int?
  buyQty             Int?
  getQty             Int?
  getDiscountPercent Int?
  minSubtotalSatang  Int?
  // Product scoping for the line-level types (1-3: PRODUCT_DISCOUNT / FIXED_PRICE /
  // BUY_X_GET_Y); EMPTY for BILL_THRESHOLD (whole-bill). A scalar String[] instead of
  // a Promotion↔Product join table BECAUSE the app DB role has no DELETE (HeldBill
  // precedent), which makes editing a join set impractical; the ids are validated to
  // exist at write time, and products are never hard-deleted (soft-delete only), so a
  // dangling id cannot appear.
  productIds String[]      @default([])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // The POS fetch selects effective promotions (isActive + the startsAt/endsAt
  // window); index the predicate columns so the per-checkout scan uses one index.
  @@index([isActive, startsAt, endsAt])
}

// Promotion kinds (promotions program, Phase 2; D1 — all four). Ordered 1-4 as the
// engine/UI reference them: a line % or ฿ discount, a special fixed price, buy-X-
// get-Y on the SAME product (v1), and a whole-bill spend threshold.
enum PromotionType {
  PRODUCT_DISCOUNT
  FIXED_PRICE
  BUY_X_GET_Y
  BILL_THRESHOLD
}
