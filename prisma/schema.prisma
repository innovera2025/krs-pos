// Prisma schema for KRS POS
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Customer / member (Phase 6a). Minimal by design: name + optional tax fields
// (taxId/address) needed to legally print a tax invoice header. The customer
// picker SELECTS seeded customers (no add-customer CRUD in 6a). A bill links to
// at most one customer (Order.customerId, nullable = walk-in). `address` carries
// the tax-invoice "ที่อยู่ออกใบกำกับ" address from the Simple POS IA.
model Customer {
  id        String   @id @default(cuid())
  name      String
  taxId     String?  @unique
  phone     String?
  address   String?
  // Buyer's RD branch designation for a full §86/4 tax invoice (Phase 4). The
  // 5-digit Revenue-Department branch code — "00000" = สำนักงานใหญ่ (head
  // office), "00001"+ = สาขาที่ N. Distinct from `branchId` below (which is the
  // SELLER's internal branch). Required on a full tax invoice so the buyer can
  // claim input VAT; defaults to HQ for the common single-branch buyer.
  buyerBranchCode String @default("00000")
  // Multi-branch-ready data model (domain-multi-branch-ready) — single-branch
  // deployments use the BR-01 default.
  branchId  String   @default("BR-01")
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// KRS accounting sync job (Phase 6a). A SIMULATED state machine — there is NO
// real KRS transport in P6; actions mutate `status` with canned responses, and
// `provider` is an open string field so other accounting providers can plug in
// later (real transport = production-readiness). 6a only creates the PENDING
// TAX_INVOICE job; the full 8-job seed + /data UI is Phase 6b.
model SyncJob {
  id        String        @id @default(cuid())
  type      SyncJobType
  direction SyncDirection @default(INSERT)
  ref       String
  amount    Decimal       @db.Decimal(12, 2) @default(0)
  status    SyncJobStatus @default(PENDING)
  provider  String        @default("KRS")
  error     String?
  response  String?
  branchId  String        @default("BR-01")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// Sync job kinds mirroring the Simple POS jobTypeLabel set (sale/refund/stock/
// pull/tax_invoice/stock_adj/receive).
enum SyncJobType {
  SALE
  REFUND
  STOCK
  PULL
  TAX_INVOICE
  STOCK_ADJ
  RECEIVE
}

// Outbound (POS → KRS) vs inbound (KRS → POS) data flow.
enum SyncDirection {
  INSERT
  PULL
}

// Sync job lifecycle states (Simple POS: pending/synced/failed/retrying/skipped).
enum SyncJobStatus {
  PENDING
  SYNCED
  FAILED
  RETRYING
  SKIPPED
}

// Store-level settings singleton (Receipt print-size feature). Exactly ONE row
// (`id @default("singleton")`) holds the admin-configurable thermal-receipt page
// size: `receiptWidthMm` (40–120, preset 58/80 + free input), and the height
// either AUTO (`receiptHeightAuto = true`, the today/default behavior matching
// `@page { size: 80mm auto }`) or a FIXED `receiptHeightMm` (50–400). When
// `receiptHeightAuto` is true `receiptHeightMm` is forced NULL by the API. Seller
// identity stays in ENV (sellerConfig.ts) and is intentionally NOT migrated here;
// the nullable slots keep the model extensible for future store settings without
// touching seller config.
model ShopSettings {
  id                String   @id @default("singleton")
  receiptWidthMm    Int      @default(80)
  receiptHeightAuto Boolean  @default(true)
  receiptHeightMm   Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role     @default(CASHIER)
  password  String
  // Activate/deactivate without a destructive delete (Phase 4 Users & Roles:
  // state-user-active-inactive). A deactivated user is hidden/blocked, never removed.
  isActive  Boolean  @default(true)
  // Account lockout (auth Phase 3). `failedLoginAttempts` counts consecutive bad
  // sign-ins; at the threshold (10) `lockedUntil` is set to now+15min. A success
  // resets both to 0/null. Auto-expires at `lockedUntil`; an admin can also clear
  // them via the {action:"unlock"} PATCH variant. Persistent (survives restart),
  // complementing the in-memory per-IP rate-limiter in src/lib/rateLimit.ts.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  // Force-logout-all (auth Phase 3). Stamped onto the JWT at sign-in; the jwt
  // callback re-reads it every request and invalidates a token whose stamped
  // version is stale. Admin "force logout" increments this → every existing JWT
  // for the user is rejected on its next request. (JWT-compatible session
  // revocation; per-device listing needs a Session table and is deferred.)
  tokenVersion        Int       @default(0)
  // Multi-branch-ready data model (domain-multi-branch-ready) — a user belongs to
  // a branch. Single-branch deployments use the BR-01 default. Surfaced in the
  // Users & Roles table and selected by the users API.
  branchId  String   @default("BR-01")
  orders    Order[]
  // Shifts this user opened/owns as cashier (Phase 5: flow-shift-lifecycle).
  shifts    Shift[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
}

// Audit trail (auth Phase 3). Append-only security/event log: who did what, to
// what, from where. Writes are BEST-EFFORT (src/lib/auditLog.ts) — a failed
// audit write never fails the primary action and is NEVER done inside a
// $transaction. `detail` holds a small JSON string for action-specific context
// (e.g. {orderNumber,total} for a refund). No FK on actorId/targetId so a row
// survives even if the referenced record is later changed.
model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  actorEmail String?
  action     AuditAction
  targetType String?
  targetId   String?
  ip         String?
  detail     String?
  createdAt  DateTime    @default(now())

  @@index([action, createdAt])
  @@index([actorId, createdAt])
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGIN_RATE_LIMITED
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  LOGOUT
  PASSWORD_CHANGED
  USER_CREATED
  USER_DEACTIVATED
  USER_ACTIVATED
  // Sale created at checkout (Financial/Inventory correctness, Sub-phase B). The
  // POST /api/orders success path writes this best-effort, AFTER commit — the
  // money-trail counterpart to ORDER_REFUNDED / ORDER_VOIDED.
  ORDER_CREATED
  ORDER_REFUNDED
  ORDER_VOIDED
  SESSION_REVOKED
  // KRS connection settings changed (krs-sync P1). Written best-effort, AFTER the
  // KrsConnectionSettings upsert commits, when `host` (or `port`) changes — the
  // compensating audit control for the deliberate no-private-IP-denylist SSRF
  // stance (P0 spec §1.2.1). `detail` holds {newHost,newPort} JSON.
  KRS_SETTINGS_CHANGED
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  sku         String      @unique
  price       Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  barcode     String?     @unique
  imageUrl    String?
  isActive    Boolean     @default(true)
  // Multi-branch-ready data model (domain-multi-branch-ready) — deferred from
  // Phase 1, added here. Single-branch deployments use the BR-01 default.
  branchId    String      @default("BR-01")
  categoryId  String?
  category    Category?   @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  movements   StockMovement[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique
  // Checkout idempotency (Financial/Inventory correctness, Sub-phase C). A
  // client-generated UUID per checkout ATTEMPT (reused across retries of the
  // same submission, regenerated for a new sale). The `@unique` index makes a
  // double-submit / network retry collapse to a single Order: the POST pre-checks
  // by this key and returns the existing order (200 replay) instead of creating a
  // duplicate sale + double stock decrement. Nullable for back-compat (older rows
  // and any client that omits it); `@unique` allows multiple NULLs in Postgres.
  idempotencyKey String?   @unique
  status       OrderStatus @default(COMPLETED)
  subtotal     Decimal     @db.Decimal(10, 2)
  tax          Decimal     @db.Decimal(10, 2) @default(0)
  discount     Decimal     @db.Decimal(10, 2) @default(0)
  total        Decimal     @db.Decimal(10, 2)
  paymentType  PaymentType @default(CASH)
  amountPaid   Decimal     @db.Decimal(10, 2) @default(0)
  change       Decimal     @db.Decimal(10, 2) @default(0)
  // Multi-branch-ready data model (domain-multi-branch-ready) — deferred from
  // Phase 1, added here. Single-branch deployments use the BR-01 default.
  branchId     String      @default("BR-01")
  cashierId    String?
  cashier      User?       @relation(fields: [cashierId], references: [id])
  // Customer linkage (Phase 6a). Nullable = walk-in (ลูกค้าทั่วไป); a checkout
  // never blocks when no customer is selected. Required (with a taxId) only when
  // a tax invoice is requested (domain-tax-invoice-requires-tax-customer).
  customerId   String?
  customer     Customer?   @relation(fields: [customerId], references: [id])
  // Shift linkage (Phase 5 Decision A2: add shiftId FK on Order). Nullable so a
  // checkout never blocks when no shift is open — the POST sets it to the current
  // OPEN shift if one exists, else leaves it null. The Z-report aggregates the
  // shift's orders by this FK.
  shiftId      String?
  shift        Shift?      @relation(fields: [shiftId], references: [id])
  // Sync lifecycle stub (Phase 5). Real KRS sync state machine is Phase 6; this
  // field exists now so the seed can express synced/daily/failed/skipped states
  // and the void-lock rule (domain-synced-bills-locked) can be enforced.
  syncStatus   SyncStatus  @default(PENDING)
  // Accounting document number (TAX-…, CN-…). The sequential §86/4 tax-invoice
  // number is minted LOCALLY at request-tax time (Phase 4, D1) and written here.
  // @unique is a DB backstop (FIX 5) against any duplicate doc number — pairs with
  // the in-tx conditional mint guard (FIX 2). Nullable: Postgres allows many NULLs
  // under a unique index, so unrequested bills (and the single seeded value) are
  // fine.
  accountingDocNo String?     @unique
  // Tax-invoice ISSUE date (§86/4(7), FIX 1). Stamped at request-tax time from the
  // SAME Postgres-now / Asia/Bangkok basis as the number mint — this is the date
  // the invoice was ISSUED, which for a post-sale request differs from
  // `createdAt` (the SALE date). The A4 document renders this; legacy rows
  // (null) fall back to createdAt.
  taxIssuedAt  DateTime?
  // Whether a tax invoice was requested for this bill (filter chip ขอใบกำกับ).
  taxRequested Boolean     @default(false)
  items        OrderItem[]
  // Split-payment breakdown (Phase 3). `paymentType` above stays the primary/
  // dominant method for reporting/back-compat; `payments` carries every tendered
  // line (method + amount + optional reference) — feeds the P5 by-method Z-report.
  payments     PaymentLine[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Recent-orders sort: GET /api/orders defaults to orderBy { createdAt: desc }
  // and Sales History lists newest-first — index the sort key.
  @@index([createdAt])
  // `?status=` filter + createdAt sort (e.g. COMPLETED-only history/aggregates):
  // composite so the filter+sort is served by one index.
  @@index([status, createdAt])
  // Z-report aggregates a shift's orders by this FK. Postgres does NOT auto-index
  // foreign keys, so add it explicitly for the per-shift lookup.
  @@index([shiftId])
}

// Collision-safe daily POS number sequence (Financial/Inventory correctness,
// Sub-phase C). One row per Asia/Bangkok calendar day; `seq` is bumped atomically
// inside the checkout transaction via a raw `INSERT ... ON CONFLICT DO UPDATE
// SET seq = seq + 1 RETURNING seq` upsert (race-free, unlike a find-then-write).
// This replaces the old count-based `nextPosNo`, which could mint duplicate
// orderNumbers under concurrent checkouts (READ COMMITTED). `orderNumber` is
// derived as `POS-${day}-${seq padded to 4}`.
model DailyOrderCounter {
  // "YYYYMMDD" in Asia/Bangkok (matches bangkokDayStamp / bangkokYyyymmdd).
  day String @id
  seq Int    @default(0)
}

// Sequential tax-invoice number counter (Phase 4 — Thai full §86/4 invoice). One
// row per Asia/Bangkok calendar YEAR; `seq` is bumped atomically at request-tax
// time via a raw `INSERT ... ON CONFLICT (year) DO UPDATE SET seq = seq + 1
// RETURNING seq` upsert — race-free, mirroring DailyOrderCounter. Yearly reset
// (D5): the issued number is `TAX-${year}-${seq padded to 6}` (matches the seed
// `TAX-2026-000418`). Minted INSIDE the request-tax transaction so a rolled-back
// request does not consume a tax-invoice number. The §86/4(4) serial requirement
// (strict ascending, no reuse) is satisfied by the atomic per-year sequence.
model TaxInvoiceCounter {
  // "YYYY" in Asia/Bangkok (derived from the Postgres transaction clock).
  year String @id
  seq  Int    @default(0)
}

enum OrderStatus {
  PENDING
  COMPLETED
  REFUNDED
  // Void ≠ Cancelled in the POS domain (Simple POS source-of-truth). A voided
  // bill is zeroed and skipped from sync; CANCELLED is kept for back-compat.
  VOIDED
  CANCELLED
}

// Sync lifecycle states (Phase 5 stub; real KRS sync = Phase 6). Mirrors the
// Simple POS sync values: pending / daily / synced / failed / skipped.
enum SyncStatus {
  PENDING
  DAILY
  SYNCED
  FAILED
  SKIPPED
}

enum PaymentType {
  CASH
  CARD
  QR
  TRANSFER
  EWALLET
  OTHER
}

model PaymentLine {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method    PaymentType
  amount    Decimal     @db.Decimal(10, 2)
  reference String?
  createdAt DateTime    @default(now())
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  lineTotal  Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
}

// Stock movement ledger (Phase 4: action-receive-stock / flow-product-stock).
// RECEIVE = goods-received note (GRN, +stock); SALE/ADJUST are reserved for
// future wiring (POS sale decrements / manual corrections). Each movement
// records the signed/positive qty plus an optional reference (e.g. PO number).
enum StockMovementType {
  RECEIVE
  SALE
  ADJUST
}

model StockMovement {
  id        String            @id @default(cuid())
  productId String
  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      StockMovementType
  qty       Int
  reference String?
  branchId  String            @default("BR-01")
  createdAt DateTime          @default(now())
}

// Cash-drawer shift (Phase 5: flow-shift-lifecycle). A shift is opened with an
// opening cash float, accumulates orders (Order.shiftId), and is closed with the
// counted cash — driving the Z-report and cash-variance. Append-only: a closed
// shift is never deleted (domain-no-destructive-delete).
model Shift {
  id           String       @id @default(cuid())
  shiftNumber  String       @unique
  status       ShiftStatus  @default(OPEN)
  openedAt     DateTime     @default(now())
  closedAt     DateTime?
  openingFloat Decimal      @db.Decimal(10, 2) @default(0)
  countedCash  Decimal?     @db.Decimal(10, 2)
  cashierId    String?
  cashier      User?        @relation(fields: [cashierId], references: [id])
  branchId     String       @default("BR-01")
  orders       Order[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum ShiftStatus {
  OPEN
  CLOSED
}

// KRS connection profile (krs-sync P1). Singleton — exactly ONE row, mirroring
// ShopSettings (id @default("singleton")). Stores the MS SQL Server connection
// parameters configured from the Admin /data Connection tab. The password is
// AES-256-GCM encrypted at rest (see encryptedPassword); plaintext never persists.
// This model is connection CONFIG only — the live mssql ConnectionPool is opened
// in src/lib/krs/client.ts, NOT here, and NEVER via the Prisma singleton.
model KrsConnectionSettings {
  id                String   @id @default("singleton")
  host              String                                  // SQL Server hostname or IP
  port              Int      @default(1433)                 // SQL Server default port
  database          String                                  // target database name
  username          String                                  // SQL Server SQL-auth username
  encryptedPassword String?                                 // AES-256-GCM blob (see lib/krs/crypto.ts); null = not yet set
  ssl               Boolean  @default(true)                 // TLS / encrypt connection (mssql options.encrypt)
  trustServerCert   Boolean  @default(true)                 // trust a self-signed KRS cert when SSL is on (on-prem-friendly; mssql options.trustServerCertificate)
  engine            String   @default("SQLSERVER")          // fixed; read-only display in UI
  syncMode          String   @default("realtime")           // "realtime" | "daily" | "manual"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
