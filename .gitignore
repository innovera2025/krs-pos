# dependencies
/node_modules
/.pnp
.pnp.js

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# test coverage (vitest --coverage output)
/coverage

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local

# database backups (dumps + globals from scripts/backup.sh — never commit data)
/backups/
*.dump

# prisma
/prisma/*.db

# typescript
*.tsbuildinfo

# claude code — personal/local overrides (shared config is .claude/settings.json)
.claude/settings.local.json

# design-tool metadata (e.g. WebP thumbnail exports under design/)
.thumbnail

# playwright e2e (runtime artifacts + downloaded browsers)
/test-results/
/playwright-report/
/playwright/.cache/
.playwright-mcp/

# local-only compose override (dev DB host port mapping; never in prod)
docker-compose.override.yml
